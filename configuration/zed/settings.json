{
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "fish": true,
    "html": true,
    "one-dark-darkened": true,
    "ruby": true,
    "toml": true,
  },
  "buffer_font_family": "Geist Mono",
  "buffer_font_features": {
    "calt": false,
    "liga": false,
  },
  "buffer_font_size": 14.4,
  "buffer_line_height": {
    "custom": 1.5,
  },
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "diagnostics": {
    "button": false,
  },
  "edit_predictions": {
    "provider": "none",
  },
  "format_on_save": "off",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "git_panel": {
    "button": false,
  },
  "indent_guides": {
    "enabled": false,
  },
  "outline_panel": {
    "button": false,
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "default_width": 260,
    "dock": "left",
    "indent_guides": {
      "show": "never",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "show_whitespaces": "none",
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "button": false,
    "font_size": 13.4,
  },
  "theme": {
    "dark": "One Dark - Darkened",
    "light": "One Dark - Darkened",
  },
  "title_bar": {
    "show_branch_name": false,
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_sign_in": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "ui_font_family": "Inter Display",
}
