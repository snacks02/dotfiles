{
  "agent_servers": {
    "claude-acp": {
      "default_model": "sonnet",
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "fish": true,
    "html": true,
    "one-dark-darkened": true,
    "oxc": true,
    "ruby": true
  },
  "buffer_font_family": "Geist Mono",
  "buffer_font_features": {
    "calt": false,
    "liga": false
  },
  "buffer_font_size": 14.6,
  "buffer_line_height": {
    "custom": 1.5
  },
  "collaboration_panel": {
    "button": false
  },
  "debugger": {
    "button": false
  },
  "diagnostics": {
    "button": false
  },
  "format_on_save": "off",
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "git_panel": {
    "button": false
  },
  "indent_guides": {
    "enabled": false
  },
  "languages": {
    "CSS": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "GraphQL": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "Handlebars": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "HTML": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "JavaScript": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "JSON": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "JSON5": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "JSONC": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "Less": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "Markdown": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "MDX": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "SCSS": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "TSX": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "TypeScript": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "Vue.js": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    },
    "YAML": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "prettier": { "allowed": false }
    }
  },
  "notification_panel": {
    "button": false
  },
  "outline_panel": {
    "button": false
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "default_width": 260,
    "indent_guides": {
      "show": "never"
    }
  },
  "session": {
    "trust_all_worktrees": true
  },
  "show_whitespaces": "none",
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "button": false
  },
  "theme": {
    "dark": "One Dark - Darkened",
    "light": "One Dark - Darkened"
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_sign_in": false
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "ui_font_family": "Inter Display"
}
